{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "minimumReleaseAge": "1 day",
  "minimumReleaseAgeBehaviour": "timestamp-optional",
  "kubernetes": {
    "managerFilePatterns": [
      "/applications/.+\\.yaml$/",
      "/argocd/.+\\.yaml$/",
      "/bootstrap/.+\\.yaml$/",
      "/system/.+\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "k0sproject/k0s",
      "managerFilePatterns": ["/k0sctl.yaml/"],
      "matchStrings": ["version: (?<currentValue>.*)"]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "cloudnative-pg/cloudnative-pg",
      "managerFilePatterns": [
        "/system\\/cloudnative-pg\\/kustomization\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=cloudnative-pg/cloudnative-pg\\s+- https://raw.githubusercontent.com/cloudnative-pg/cloudnative-pg/v(?<currentValue>.*?)/releases/cnpg-.*?\\.yaml"
      ],
      "autoReplaceStringTemplate": "# renovate: datasource=github-releases depName=cloudnative-pg/cloudnative-pg\n  - https://raw.githubusercontent.com/cloudnative-pg/cloudnative-pg/v{{{newValue}}}/releases/cnpg-{{{newValue}}}.yaml"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kubernetes/kubernetes",
      "managerFilePatterns": ["/talconfig\\.yaml$/"],
      "matchStrings": [
        "(?:^|\\r\\n|\\r|\\n)kubernetesVersion:\\s(?<currentValue>v?[^\\s]+)(?:\\r\\n|\\r|\\n|$)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "siderolabs/talos",
      "managerFilePatterns": ["/talconfig\\.yaml$/"],
      "matchStrings": [
        "(?:^|\\r\\n|\\r|\\n)talosVersion:\\s(?<currentValue>v?[^\\s]+)(?:\\r\\n|\\r|\\n|$)"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "managerFilePatterns": ["/kustomization.yaml/"],
      "matchStrings": [
        "https://github.com/(?<depName>cert-manager/cert-manager|emberstack/kubernetes-reflector|open-telemetry/opentelemetry-operator|prometheus-operator/prometheus-operator)/releases/download/(?<currentValue>.*?)/"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-tags",
      "managerFilePatterns": ["/kustomization.yaml/"],
      "matchStrings": [
        "https://raw.githubusercontent.com/(?<depName>argoproj/argo-cd|zebernst/synology-csi-talos)/(?<currentValue>.*?)/"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": ["/.*\\.yaml/"],
      "matchStrings": [
        "#\\s?renovate: image=(?<depName>.*?)\\s+(?:tag|version):\\s?[\"']?(?<currentValue>[\\w+\\.\\-]*)[\"']?"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "managerFilePatterns": ["/talconfig\\.yaml$/"],
      "matchStrings": [
        "image:\\s?(factory.talos.dev/[^:]+):(?<currentValue>.*)"
      ],
      "depNameTemplate": "siderolabs/talos"
    }
  ],
  "packageRules": [
    {
      "groupName": "Mastodon",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/mastodon/mastodon",
        "ghcr.io/mastodon/mastodon-streaming"
      ]
    },
    {
      "groupName": "Talos",
      "matchDatasources": ["github-releases"],
      "matchPackageNames": ["siderolabs/talos"]
    },
    {
      "groupName": "OpenTelemetry Collector Materia Distribution",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/rokoucha/otelcol/**"],
      "versioning": "regex:^(?<major>\\d{8})\\.(?<minor>\\d{6})$"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/starrybluesky/mirakurun-custom"],
      "versioning": "regex:^(?<major>\\d{4})\\.(?<minor>\\d{1,2})\\.(?<patch>\\d{1,2})$"
    }
  ]
}
