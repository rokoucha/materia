{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard"],
  "kubernetes": {
    "managerFilePatterns": [
      "/applications/.+\\.yaml$/",
      "/argocd/.+\\.yaml$/",
      "/bootstrap/.+\\.yaml$/",
      "/system/.+\\.yaml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "k0sproject/k0s",
      "managerFilePatterns": ["/k0sctl.yaml/"],
      "matchStrings": ["version: (?<currentValue>.*)"]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "cloudnative-pg/cloudnative-pg",
      "managerFilePatterns": [
        "/system\\/cloudnative-pg\\/kustomization\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=github-releases depName=cloudnative-pg/cloudnative-pg\\s+- https://github.com/cloudnative-pg/cloudnative-pg/releases/download/v(?<currentValue>.*?)/cnpg-.*?\\.yaml"
      ],
      "autoReplaceStringTemplate": "# renovate: datasource=github-releases depName=cloudnative-pg/cloudnative-pg\n  - https://github.com/cloudnative-pg/cloudnative-pg/releases/download/v{{{newValue}}}/cnpg-{{{newValue}}}.yaml"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "managerFilePatterns": ["/kustomization.yaml/"],
      "matchStrings": [
        "https://github.com/(?<depName>.*/.*?)/releases/download/(?<currentValue>.*?)/"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-tags",
      "managerFilePatterns": ["/kustomization.yaml/"],
      "matchStrings": [
        "https://raw.githubusercontent.com/(?<depName>[^/]*/[^/]*)/(?<currentValue>.*?)/"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": ["/.*\\.yaml/"],
      "matchStrings": [
        "#\\s?renovate: image=(?<depName>.*?)\\s+(?:tag|version):\\s?[\"']?(?<currentValue>[\\w+\\.\\-]*)[\"']?"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "managerFilePatterns": ["/.*\\.yaml/"],
      "matchStrings": [
        "image:\\s?(factory.talos.dev/[^:]+):(?<currentValue>.*)"
      ],
      "depNameTemplate": "siderolabs/talos"
    }
  ],
  "packageRules": [
    {
      "groupName": "Mastodon",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "ghcr.io/mastodon/mastodon",
        "ghcr.io/mastodon/mastodon-streaming"
      ]
    },
    {
      "groupName": "OpenTelemetry Collector Materia Distribution",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/rokoucha/otelcol/**"],
      "versioning": "regex:^(?<major>\\d{8})\\.(?<minor>\\d{6})$"
    }
  ]
}
